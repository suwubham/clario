
# Clario Backend - PRODUCTION Environment Variables
# Copy to .env and fill in with actual production values
# NEVER commit actual secrets to version control

# ===== REQUIRED =====
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_SECRET_KEY=your-production-service-role-key-here
GEMINI_API_KEY=your-production-gemini-api-key-here

# ===== PRODUCTION SETTINGS =====
ENV=production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS: Your production domain(s) - MUST be specific, not wildcards
# Multiple domains: domain1.com,domain2.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# Optional: Specific AI model for reports
# GEMINI_REPORT_MODEL=gemini-2.0-flash

# Optional: Monitoring & Logging
# LOG_LEVEL=INFO
# SENTRY_DSN=https://your-sentry-dsn

