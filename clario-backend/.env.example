SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the service_role secret (not anon) so the backend can call PostgREST without RLS blocking inserts.
SUPABASE_SECRET_KEY=your-service-role-secret

GEMINI_API_KEY=your-gemini-api-key
# Optional: model for POST /sessions/{id}/report (default gemini-2.0-flash)
# GEMINI_REPORT_MODEL=gemini-2.0-flash
