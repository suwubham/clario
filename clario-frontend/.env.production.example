# Clario Frontend - PRODUCTION Environment Variables
# Copy to .env and fill in with actual production values
# Public keys are safe to commit; NEVER expose secret keys here

# Supabase Configuration (use publishable key, not secret)
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-production-publishable-key

# Backend API URL - your production API domain
VITE_BACKEND_BASE_URL=https://api.yourdomain.com
